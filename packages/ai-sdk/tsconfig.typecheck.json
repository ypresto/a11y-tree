{
  // Type-check without emitting, resolving the a11y-tree (core) package from
  // source so this package can be type-checked without building core first. The
  // build (tsconfig.json) instead resolves it from its published types in dist.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "a11y-tree": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
