{
  "name": "@a11y-tree/ai-sdk",
  "version": "0.1.0",
  "description": "Vercel AI SDK tools that drive the current page's live DOM via a11y-tree — for in-browser conversation agents.",
  "author": "ypresto <yuya.presto@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ypresto/a11y-tree.git",
    "directory": "packages/ai-sdk"
  },
  "homepage": "https://github.com/ypresto/a11y-tree/tree/main/packages/ai-sdk",
  "bugs": {
    "url": "https://github.com/ypresto/a11y-tree/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "a11y-tree",
    "ai-sdk",
    "vercel-ai-sdk",
    "ai",
    "tools",
    "agent",
    "playwright",
    "dom",
    "mcp"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "a11y-tree": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "ai": "^5.0.0",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
