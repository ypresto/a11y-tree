{
  "name": "a11y-tree",
  "version": "0.1.0",
  "description": "Playwright-compatible accessibility tree for the live DOM — snapshot it, reference it, drive it (click/type/fill).",
  "author": "ypresto <yuya.presto@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ypresto/a11y-tree.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ypresto/a11y-tree/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/ypresto/a11y-tree/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "a11y-tree",
    "aria",
    "aria-snapshot",
    "accessibility-tree",
    "playwright",
    "dom",
    "automation",
    "agent",
    "mcp"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepack": "cp ../../README.md README.md",
    "postpack": "rm -f README.md"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
